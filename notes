 ---

How do I calculate BMI?
 To compute BMI, you need to:
  Divide your weight (in kilograms) by your height (in meters).
  Divide the answer by your height again to get your BMI.
   [weight(kg)/height(m)]/height
  That is the body mass index formula. Expressed differently, it is:
   BMI = weight / height²

There are five basic ranges within the BMI scale:
 Underweight = less than 18.5;
 Normal weight = 18.5-24.9;
 Overweight = 25-29.9;
 Obesity = 30-35;
 Severe obesity = 35 and over.

Coversions
1ft = 30.48 cm
1m  = 3.28084 ft
100cm = 1 m



let title = document.getElementById("title");
let description = document.getElementById("description");

title.addEventListener("input", checkTitle);
description.addEventListener("input", checkDescription);

function checkTitle() {

  let text = title.value;
  let status = document.getElementById("titleStatus");
  let preview = document.getElementById("previewTitle");

  preview.innerText = text;

  if (text.length < 50) {
    status.innerText = "Title too short";
    status.style.color = "red";
  }
  else if (text.length <= 60) {
    status.innerText = "Optimal title length";
    status.style.color = "green";
  }
  else {
    status.innerText = "Title too long";
    status.style.color = "orange";
  }
}

function checkDescription() {

  let text = description.value;
  let status = document.getElementById("descStatus");
  let preview = document.getElementById("previewDesc");

  preview.innerText = text;

  if (text.length < 120) {
    status.innerText = "Description too short";
    status.style.color = "red";
  }
  else if (text.length <= 160) {
    status.innerText = "Optimal description";
    status.style.color = "green";
  }
  else {
    status.innerText = "Description too long";
    status.style.color = "orange";
  }
}